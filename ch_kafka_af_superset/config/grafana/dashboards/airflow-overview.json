      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(af_agg_dag_task_duration_bucket[5m])) by (le, dag_id))",
          "legendFormat": "{{dag_id}} p95",
          "refId": "A"
        }
      ],
      "title": "Task duration p95 by DAG",
      "type": "timeseries"
    }
