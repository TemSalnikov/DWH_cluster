      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "airflow-postgres" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "count" }]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT state, COUNT(*) AS count FROM dag_run WHERE execution_date > NOW() - INTERVAL '24 hours' GROUP BY state ORDER BY count DESC",
          "refId": "A"
        }
      ],
      "title": "DAG runs (24h) by state",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "airflow-postgres" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "failed_tasks" }]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT dag_id, COUNT(*) AS failed_tasks FROM task_instance WHERE state = 'failed' AND start_date > NOW() - INTERVAL '24 hours' GROUP BY dag_id ORDER BY failed_tasks DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Failed tasks by DAG (24h)",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
